@using Microsoft.AspNetCore.Identity
@model IEnumerable<WebApplication1.Models.Post>
@inject UserManager<User> UserManager
@{
    ViewData["Title"] = @UserManager.GetUserName(User) + "'s Profile";
}

<section id="profile">
    @if(ViewBag.Message != null)
    {
        <p>@ViewBag.Message</p>
    }
    <div class="card p-3 ">
        <div class="row">
            <div class="col-sm">
                <div id="card-img-empty">
                    @if(ViewBag.Upload != null)
                    {
                        <img src="@ViewBag.Message" height="100%" width="100%" />
                    }

                </div>
                <form asp-controller="Account" asp-action="Upload" method="post" enctype="multipart/form-data">
                    <input type="file" name="file"/>
                    <input type="hidden" name="user" value="@UserManager.GetUserId(User)"/>
                    <button type="submit">Upload Image</button>
                </form>
            </div>
            <div class="col-sm-9">
                <div class="card-body ">
                    <h1>@ViewData["Title"]</h1>

                    <p>this is the profile page</p>

                </div>

            </div>
        </div>
    </div>


    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Title)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.CreatedAt)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.UpdatedAt)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Title)
                    </td>
    
                    <td>
                        @Html.DisplayFor(modelItem => item.CreatedAt)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.UpdatedAt)
                    </td>
                    <td>
                        <a asp-controller="Post" asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                        <a asp-controller="Post" asp-action="Details" asp-route-id="@item.Id">Details</a> |
                        <a asp-controller="Post" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</section>


