@model IEnumerable<WebApplication1.Models.User>

@{
    Layout = "_AdminLayout";
}

<h1>Dashboard</h1>


<section>
 <div class="row">
    <div class="col-md-6">
      <h3>Recent views</h3> 
      <div class="table-responsive">
        <table id="ip-table" class="table">
                <thead>
                    <tr>
                        <th scope="col">User</th>
                        <th scope="col">Path</th>
                        <th scope="col">Address</th>
                        <th scope="col">Zip</th>
                    </tr>
                </thead>
                <tbody>

                    @if(ViewBag.Views != null)
                    {
                        @foreach(  var item in ViewBag.Views)
                        {
                            <tr>
                                <td>@(item.UserId != "" ? item.UserId :"Unauthenticated")</td>
                                <td>@item.Path</td>
                                <td>@item.Address</td>
                                <td>@item.Zip</td>
                            </tr>
                        }

                    }
                </tbody>
            </table>

      </div>
    </div>
    <div class="col-md-6">
        <h3>IP traffic</h3>
        <canvas id="ip-tracker"></canvas>
    </div>

 </div>
</section>



@await Html.PartialAsync("_ChartPartial")
