@model WebApplication1.ViewModels.SettingsViewModel;
@{
    Layout = "_AdminLayout";
}


<h1>Settings</h1>


<section>
    <div class="row">
        <form asp-action="Settings">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row">
                <div class="form-group col">
                    <label asp-for="Setting.Key" class="control-label"></label>
                    <input asp-for="Setting.Key" class="form-control" />
                    <span asp-validation-for="Setting.Key" class="text-danger"></span>
                </div>
                <div class="form-group col">
                    <label asp-for="Setting.Value" class="control-label"></label>
                    <input asp-for="Setting.Value" class="form-control" />
                    <span asp-validation-for="Setting.Value" class="text-danger"></span>
                </div>
                    <div class="form-group col-2">
                    <label asp-for="Setting.IsInt" class="control-label"></label>
                    <select asp-for="Setting.IsInt" class="form-control" >
                        <option value="0">False</option>
                        <option value="1">True</option>
                    </select>
                    <span asp-validation-for="Setting.IsInt" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group my-5">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
    <div class="row">

        @if (Model.Settings !=null && Model.Settings.Any())
        {
            @foreach (var item in Model.Settings)
            {
                <div class="row">
                    <div class="form-group col"><input class="form-control" type="text" disabled value="@item.Key" /></div>
                    <div class="form-group col"><input class="form-control" type="text" disabled value="@item.Value" /></div>
                </div>
                <hr class="my-3" />
            }

        }
        else
        {
            <p>Nothing here yet</p>
        }
    </div>
</section>

